{
  "manifest_version": 3,
  "name": "TypeGG Goal Tracker",
  "version": "10.17",
  "description": "Track your goals directly on TypeGG",
  "host_permissions": [
    "*://*.typegg.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.typegg.io/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "extension_icon.png",
    "32": "extension_icon@32px.png",
    "48": "extension_icon@48px.png",
    "128": "extension_icon@128px.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "typegg-goal-tracker@jetpack",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["authenticationInfo"]
      }
    }
  }
}